# Copie para .env e preencha. Todas as chaves são OPCIONAIS — cada fonte
# degrada com elegância quando a credencial correspondente falta.

# Senha do painel Streamlit (defina a sua — sem valor, o painel fica bloqueado)
APP_PASSWORD=defina-uma-senha-forte

# Google Places API (New) — habilita a fonte "google_places"
# Console: https://console.cloud.google.com  → Places API (New)
GOOGLE_PLACES_API_KEY=

# Sympla — token da API oficial (eventos da própria conta/parceiro)
SYMPLA_TOKEN=

# CNPJá — habilita busca de empresas por CNAE na fonte "cnpj"
# https://cnpja.com  (a busca por LISTA de CNPJs funciona sem isso, via BrasilAPI)
CNPJ_SEARCH_TOKEN=

# Agendor — envio dos leads direto para o CRM (mesma conta do BI de Faturamento)
AGENDOR_TOKEN=

# Ajustes de rede / cache (opcionais)
HTTP_TIMEOUT=25
HTTP_RETRIES=3
CACHE_TTL_HORAS=168
